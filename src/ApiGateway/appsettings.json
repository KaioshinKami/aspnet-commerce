{
  "Jwt": {
    "Key": "SuperSecretKey_CarRental_2024_ChangeMe!",
    "Issuer": "CarRentalIdentity",
    "Audience": "CarRentalClients"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/identity/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/identity" }]
      },
      "vehicle-route": {
        "ClusterId": "vehicle-cluster",
        "Match": { "Path": "/vehicles/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/vehicles" }]
      },
      "booking-route": {
        "ClusterId": "booking-cluster",
        "Match": { "Path": "/bookings/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/bookings" }]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://identity-service:8080" }
        }
      },
      "vehicle-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://vehicle-service:8080" }
        }
      },
      "booking-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://booking-service:8080" }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" }
  }
}
